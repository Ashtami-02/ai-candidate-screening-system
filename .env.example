# Copy this file to .env and fill in real values. Never commit .env itself.

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Path where the vector database will store its files
CHROMA_PERSIST_DIR=./data/chroma_store

# SQLite database file
DATABASE_URL=sqlite:///./data/interview_system.db
